# ============================================================
# Coffee Connoisseur Platform — Environment Variables
# Copy this file to .env and fill in values for local dev.
# Production secrets are fetched from AWS Secrets Manager.
# ============================================================

# --- Shared ---
ENVIRONMENT=dev

# --- Database (set automatically by docker-compose for containers) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/coffee

# --- Auth Service ---
JWT_SECRET=dev-jwt-secret-replace-in-production-with-32-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Inter-Service URLs ---
AUTH_SERVICE_URL=http://localhost:8001

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI (coffee-service AI recommendations) ---
OPENAI_API_KEY=

# --- Email (security-service alerts, auth email verification) ---
SENDGRID_API_KEY=

# --- AWS (production only — leave blank for dev) ---
AWS_REGION=us-east-1
SECRET_NAME=coffee/production

# --- CORS ---
# Comma-separated origins
CORS_ORIGINS=http://localhost:3000
